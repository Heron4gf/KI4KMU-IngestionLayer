# ChromaDB Configuration
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=documents

# Unstructured API Configuration
UNSTRUCTURED_URL=http://unstructured:8000/general/v0/general
UNSTRUCTURED_CHUNKING_STRATEGY=by_title
UNSTRUCTURED_MAX_CHARACTERS=1000
UNSTRUCTURED_OVERLAP=150

# LMStudio Configuration
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=your-model-name

# Caption Configuration
CAPTION_MAX_TOKENS=256
CAPTIONER_PROMPT_PATH=/prompts/captioner.md

# GraphDB
GRAPHDB_VERSION=10.7.0
GRAPHDB_PORT=7200
GDB_JAVA_OPTS=-Dgraphdb.workbench.importDirectory=/opt/graphdb/home/import

# GraphDB Writer
GRAPHDB_URL=http://graphdb:7200
GRAPHDB_REPOSITORY=pdf-ingestion
GRAPHDB_BASE_NS=http://pdf-ingestion/ontology/

# Optional
GRAPHDB_USER=
GRAPHDB_PASSWORD=

# LangExtract Service
LANGEXTRACT_PORT=8003
LANGEXTRACT_BASE_URL=http://host.docker.internal:1234/v1
LANGEXTRACT_API_KEY=lm-studio
LANGEXTRACT_MODEL_ID=openai/gpt-4o
LANGEXTRACT_PROMPT_PATH=/prompts/extract.md
