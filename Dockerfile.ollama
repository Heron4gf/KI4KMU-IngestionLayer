FROM ollama/ollama:latest AS builder

WORKDIR /root

COPY models /models

RUN mkdir -p /root/.ollama/models \
 && cp /models/Qwen3.5-0.8B-Q8_0.gguf /root/.ollama/models/ \
 && echo "FROM ./Qwen3.5-0.8B-Q8_0.gguf" > /root/.ollama/models/Modelfile \
 && OLLAMA_MODELS=/root/.ollama/models ollama serve & \
    sleep 5 && \
    OLLAMA_MODELS=/root/.ollama/models ollama create qwen3.5 -f /root/.ollama/models/Modelfile || true

FROM ollama/ollama:latest

WORKDIR /root

COPY --from=builder /root/.ollama /root/.ollama

ENV OLLAMA_HOST=0.0.0.0:11434

CMD ["serve"]
